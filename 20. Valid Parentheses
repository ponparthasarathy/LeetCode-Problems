class Solution {
    public boolean isValid(String s) {
        Stack<Character> stacky = new Stack<>();
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch=='('||ch=='['||ch=='{'){
                stacky.push(ch);
            }
            else{
                if(stacky.isEmpty()){
                    return false;
                }
                char top=stacky.peek();
                if(ch==')' && top=='(' ||ch==']' && top=='[' || ch=='}' && top=='{'){
                    stacky.pop();
                }
                else{
                    return false;
                }
            }
        }
    return stacky.isEmpty();
    }
}
