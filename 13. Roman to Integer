class Solution {
    int value(char ch){
        if(ch=='I') return 1;
        if(ch=='V') return 5;
        if(ch=='X') return 10;
        if(ch=='L') return 50;
        if(ch=='C') return 100;
        if(ch=='D') return 500;
        if(ch=='M') return 1000;
        return 0;
    }
    public int romanToInt(String s) {
        int current=0, next=0;
        int result=0;
        for(int i=0;i<s.length();i++){
            current=value(s.charAt(i));
            if(i<s.length()-1){
                next=value(s.charAt(i+1));
            }
            else{
                next=0;
            }
            
            if(current>=next){
                result+=current;
            }
            else{
                result-=current;
            }
        }
        return result;
    }
}
